{
  "name": "autosphere-backend",
  "version": "1.0.0",
  "description": "AutoSphere Web Backend API",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --delay 1 src/server.js",
    "start": "node src/server.js",
    "build": "echo 'No build step needed for JavaScript'",
    "test": "vitest --run",
    "test:e2e": "vitest --run src/tests/e2e",
    "test:unit": "vitest --run src/server.test.js",
    "test:watch": "vitest",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --ext .js --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:seed": "npx sequelize-cli db:seed:all",
    "db:reset": "npx sequelize-cli db:migrate:undo:all && npm run db:migrate && npm run db:seed",
    "db:setup-dev": "node setup-dev-db.js",
    "db:create": "npx sequelize-cli db:create",
    "db:drop": "npx sequelize-cli db:drop"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.19.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "redis": "^4.6.10",
    "sequelize": "^6.35.1",
    "socket.io": "^4.7.4",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "eslint": "^8.53.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "sequelize-cli": "^6.6.2",
    "supertest": "^6.3.3",
    "vitest": "^0.34.6"
  }
}
